# Public application URL
APP_DOMAIN=example.com
APP_ORIGIN=https://example.com

# Frontend
FRONTEND_PORT=80
FRONTEND_BIND_ADDRESS=0.0.0.0
VITE_API_BASE_URL=/api
VITE_YANDEX_MAPS_API_KEY=

# PostgreSQL
POSTGRES_DB=petcare
POSTGRES_USER=petcare
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
POSTGRES_PORT=5432
POSTGRES_BIND_ADDRESS=127.0.0.1
DATABASE_URL=postgresql+asyncpg://petcare:CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD@postgres:5432/petcare

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
MINIO_BUCKET_PRIVATE=petcare-private
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=files.example.com
MINIO_SECURE=false
MINIO_PUBLIC_SECURE=true
MINIO_REGION=us-east-1
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BIND_ADDRESS=127.0.0.1
MINIO_PRESIGNED_UPLOAD_TTL_SEC=900
MINIO_PRESIGNED_DOWNLOAD_TTL_SEC=3600

# Auth
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_A_64_HEX_CHARACTER_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Backend
ENV=production
BACKEND_CORS_ORIGINS=https://example.com
ENABLE_ADMIN_IMPORTS=false
INVITE_BASE_URL=https://example.com/invite
YANDEX_GEOCODER_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_INTERNAL_TOKEN=
